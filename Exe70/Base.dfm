  object JROrderFormQuery: TQuery
    DatabaseName = 'RMP'
    SQL.Strings = (
      'select a.id, a.number, b.name, c.name, a.date_in, a.date_out, '
      'a.pr_exec, a.id_rqst, a.id_pdr, d.name, d.id, f.name'
      
        'from dh_order a, spr_pdr b, spr_nmnt c, spr_cst d, dh_rqst e, sp' +
        'r_pdr f'
      'where b.id = a.id_pdr and'
      '           c.id = a.id_nmnt and'
      '           d.id = e.id_cst and'
      '           e.id = a.id_rqst and'
      '           e.id_pdr = f.id and'
      '           a.date_in >= :dateIn and'
      '           a.date_out <= :dateOut')
    Left = 544
    Top = 108
    ParamData = <
      item
        DataType = ftUnknown
        Name = 'dateIn'
        ParamType = ptUnknown
      end
      item
        DataType = ftUnknown
        Name = 'dateOut'
        ParamType = ptUnknown
      end>
  end
  object JRRQSTFormQuery: TQuery
    AfterScroll = JRRQSTFormQueryAfterScroll
    DatabaseName = 'RMP'
    SQL.Strings = (
      
        'select a.id, a.number, a.date_in, a.date_out, b.name, c.name, a.' +
        'pr_exec'
      'from dh_rqst a, spr_pdr b, spr_cst c'
      'where '
      '      b.id = a.id_pdr and'
      '      c.id = a.id_cst and'
      '      a.date_in >= :dateIn and'
      '      a.date_in <= :dateOut'
      ' '
      'order by a.date_in')
    Left = 544
    Top = 342
    ParamData = <
