  object MainCalculateQuery: TQuery
    DatabaseName = 'RMP'
    SQL.Strings = (
      
        'select calc.id, calc.name, pdr.name, b.nvalue, calc.is_int, calc' +
        '.code'
      'from spr_calc calc, spr_clcmvz b, spr_pdr pdr, spr_vop vop'
      'where calc.id = b.id_calc and'
      '      b.id_pdr = vop.id_pdr and'
      '      pdr.id   = vop.id_pdr and'
      '      vop.id = :idvop')
    Left = 90
    Top = 190
    ParamData = <
      item
        DataType = ftUnknown
        Name = 'idvop'
        ParamType = ptUnknown
      end>
  end
